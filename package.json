    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/amin-abbasi/node-performance-gotchas/issues"
    },
    "homepage": "https://github.com/amin-abbasi/node-performance-gotchas#readme",
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.3",
        "cross-env": "^10.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "express": "^5.2.1",
        "gach": "^1.7.5"
    }
}
