{
    "name": "node-performance-gotchas",
    "version": "4.0.0",
    "description": "Demonstrating Node.js memory leaks, backpressure, and event loop blocking",
    "main": "dist/app.js",
    "scripts": {
        "build": "tsc",
        "start": "ts-node src/server.ts",
        "dev": "cross-env NODE_OPTIONS=--expose-gc ts-node src/server.ts",
        "spam:safe": "node scripts/spam.mjs safe",
        "spam:leak": "node scripts/spam.mjs leak",
        "spam:block": "node scripts/spam-block.mjs",
        "spam:stream": "node scripts/spam-stream.mjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/amin-abbasi/node-performance-gotchas.git"
    },
    "keywords": [],
    "author": "",
